<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portfolio Management</title>
    <style>
        :root {
            --primary: #10b981; /* Emerald Green */
            --primary-hover: #059669;
            --danger: #ef4444;
            --bg: #f8fafc;
            --text-dark: #1e293b;
            --card-bg: #ffffff;
        }

        body {
            margin: 0;
            padding: 40px 20px;
            background-color: var(--bg);
            color: var(--text-dark);
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
        }

        .dashboard-card {
            max-width: 900px;
            margin: 0 auto;
            background: var(--card-bg);
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        }

        header {
            border-bottom: 2px solid #f1f5f9;
            margin-bottom: 30px;
            padding-bottom: 10px;
        }

        h1 {
            font-size: 1.75rem;
            font-weight: 800;
            margin: 0;
        }

        h1 span { color: var(--primary); }

        .instruction {
            color: #64748b;
            font-size: 0.95rem;
            margin-bottom: 25px;
        }

        /* Form Styling */
        .upload-section {
            display: flex;
            gap: 10px;
            margin-bottom: 30px;
            padding: 20px;
            background: #f1f5f9;
            border-radius: 8px;
            align-items: center;
        }

        input[type="file"] {
            flex-grow: 1;
            padding: 8px;
            background: white;
            border-radius: 4px;
            border: 1px solid #cbd5e1;
        }

        button {
            background-color: var(--primary);
            color: white;
            padding: 10px 24px;
            border: none;
            border-radius: 6px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        button:hover {
            background-color: var(--primary-hover);
            transform: translateY(-1px);
        }

        /* Table Styling */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }

        th {
            text-align: left;
            background-color: #f8fafc;
            color: #64748b;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.05em;
            padding: 12px 15px;
            border-bottom: 2px solid #e2e8f0;
        }

        td {
            padding: 15px;
            border-bottom: 1px solid #f1f5f9;
            font-size: 0.95rem;
        }

        tr:hover { background-color: #fcfcfc; }

        .file-link {
            color: var(--primary);
            text-decoration: none;
            font-weight: 500;
        }

        .file-link:hover { text-decoration: underline; }

        /* Action Buttons */
        .btn-action {
            text-decoration: none;
            font-size: 0.85rem;
            padding: 6px 12px;
            border-radius: 4px;
            margin-right: 5px;
            display: inline-block;
        }

        .btn-edit {
            background: #e0f2fe;
            color: #0369a1;
        }

        .btn-delete {
            background: #fee2e2;
            color: #b91c1c;
        }

        .btn-action:hover { opacity: 0.8; }

    </style>
</head>
<body>

<div class="dashboard-card">
    <header>
        <h1>Online <span>File</span> Manager</h1>
    </header>

    <p class="instruction">
        <strong>Tip:</strong> Rename your files before uploading to keep your workspace organized and searchable.
    </p>

    <form class="upload-section" action="/upload" method="POST" enctype="multipart/form-data">
        <input type="file" name="uploads" required>
        <button type="submit">Upload File</button>
    </form>

    <section>
        <h2 style="font-size: 1.2rem; margin-bottom: 15px;">Documents</h2>
        <table>
            <thead>
                <tr>
                    <th style="width: 10%;">ID</th>
                    <th style="width: 60%;">File Name</th>
                    <th style="width: 30%;">Actions</th>
                </tr>
            </thead>
            <tbody>
                <% uploads.forEach(doc => { %>
                    <tr>
                        <td style="color: #94a3b8;">#<%= doc.id %></td>
                        <td>
                            <a class="file-link" href="<%= doc.file_path %>" download>
                                📄 <%= doc.filename %>
                            </a>
                        </td>
                        <td>
                            <a href="/edit/<%= doc.id %>" class="btn-action btn-edit" onclick="return confirm('Update this document?')">Update</a>
                            <a href="/delete/<%= doc.id %>" class="btn-action btn-delete" onclick="return confirm('Are you sure you want to delete this?')">Delete</a>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </section>
</div>

</body>
</html>